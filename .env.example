# Copy to `.env` and fill in from Supabase → Project Settings → API.
# These are the PUBLIC project URL and anon key — safe to ship in a client;
# they are protected by Row-Level Security. Never put the service_role key here.
#
# The EXPO_PUBLIC_ prefix is required — Expo only inlines env vars with it.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
